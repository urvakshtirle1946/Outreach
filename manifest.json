{
  "manifest_version": 3,
  "name": "Outly — AI HR Outreach Agent",
  "version": "1.0.0",
  "description": "Find hiring HRs on LinkedIn and send personalized cold emails automatically.",
  "permissions": ["activeTab", "storage", "scripting", "cookies", "identity"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://localhost:3000/*",
    "https://*.up.railway.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/search/results/content/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "icons/icon48.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
